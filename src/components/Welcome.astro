---
const topics = [
  {
    title: "HTML",
    href: "/html",
    description:
      "Master HTML fundamentals including semantic markup, accessibility, forms, and best practices for modern web development.",
    icon: "/html.png",
    questions: 48,
  },
  {
    title: "CSS & Tailwind",
    href: "/css-tailwind-scss",
    description:
      "Explore CSS fundamentals, Tailwind CSS utility framework, SCSS preprocessing, animations, and responsive design techniques.",
    icon: "/css.png",
    questions: 52,
  },
  {
    title: "JavaScript",
    href: "/javascript",
    description:
      "Learn JavaScript fundamentals, ES6+ features, async/await, closures, prototypes, and advanced programming patterns.",
    icon: "/js.webp",
    questions: 58,
  },
  {
    title: "DOM",
    href: "/dom",
    description:
      "Master Document Object Model manipulation, event handling, element traversal, and dynamic content modification techniques.",
    icon: "/dom.webp",
    questions: 42,
  },
  {
    title: "Angular",
    href: "/angular",
    description:
      "Learn Angular framework including components, services, dependency injection, RxJS, routing, and reactive forms development.",
    icon: "/angular.png",
    questions: 55,
  },
  {
    title: "React",
    href: "/react",
    description:
      "Master React including hooks, state management, component lifecycle, context API, performance optimization, and best practices.",
    icon: "/react.webp",
    questions: 61,
  },
];

const totalQuestions = topics.reduce((sum, topic) => sum + topic.questions, 0);
---

<style>
  @keyframes glowPulse {
    0%,
    100% {
      box-shadow: 0 0 20px rgba(255, 20, 147, 0.3);
    }
    50% {
      box-shadow: 0 0 30px rgba(255, 20, 147, 0.5);
    }
  }

  .card-hover:hover {
    animation: glowPulse 0.6s ease-in-out;
  }
</style>

<div
  class="min-h-screen font-sans"
  style="background: linear-gradient(to bottom right, #1f1472, #37147d, #53199e); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;"
>
  <!-- Navigation -->

  <!-- Hero Section -->
  <div class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <h1 class="text-6xl font-bold mb-4 text-white">
        Frontend Developer Reference Guide
      </h1>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto">
        A comprehensive guide to master frontend development concepts. Learn key
        concepts in HTML, CSS, Tailwind, JavaScript, DOM, Angular, React, and
        more.
      </p>
    </div>

    <!-- Tabs/Buttons -->
    <div class="flex justify-center gap-6 mb-16 flex-wrap">
      <span
        class="px-6 py-2 rounded-full border-2 border-pink-500 text-pink-400 font-semibold"
      >
        {totalQuestions}+ Questions
      </span>
      <span
        class="px-6 py-2 rounded-full border-2 border-pink-500 text-pink-400 font-semibold"
      >
        Code Examples
      </span>
      <span
        class="px-6 py-2 rounded-full border-2 border-pink-500 text-pink-400 font-semibold"
      >
        Quick Reference
      </span>
    </div>

    <!-- Topics Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {
        topics.map((topic) => (
          <a href={topic.href} class="group block">
            <div class="h-full bg-white/90 backdrop-blur-sm rounded-xl p-6 border border-pink-100 hover:border-pink-300 transition-all duration-300 hover:transform hover:scale-105 shadow-sm hover:shadow-lg">
              <div class="flex items-start justify-between mb-4">
                <div class="w-14 h-14 rounded-lg flex items-center justify-center">
                  <img
                    src={topic.icon}
                    alt={topic.title}
                    class="w-10 h-10 object-contain"
                  />
                </div>
                <span class="px-2 py-1 bg-pink-100 text-pink-600 text-xs font-medium rounded-full">
                  {topic.questions} Q&A
                </span>
              </div>
              <h2 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-pink-600 transition-colors">
                {topic.title}
              </h2>
              <p class="text-gray-500 text-sm leading-relaxed">
                {topic.description}
              </p>
              <div class="mt-4 flex items-center text-pink-600 text-sm font-medium">
                <span>Learn more</span>
                <svg
                  class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</div>
