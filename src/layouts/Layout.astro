---
import "../styles/global.css";
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Frontend Reference Guide</title>
  </head>
  <body>
    <nav
      class="sticky top-0 z-50 border-b border-white/10"
      style="background: rgba(31, 20, 114, 0.85); backdrop-filter: blur(12px);"
    >
      <div
        class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <a href="/" class="text-white text-2xl font-bold">Frontend Vault</a>
        {!isHome && <a href="/" class="text-gray-300 hover:text-white transition">← Back</a>}
      </div>
    </nav>
    <slot />
  </body>
</html>
