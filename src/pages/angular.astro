<Layout>
  <div
    class="min-h-screen"
    style="background: linear-gradient(to bottom right, #1f1472, #37147d, #53199e);"
  >
    <!-- Main Content -->
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="mb-12">
        <h1 class="text-5xl font-bold text-white mb-4">Angular 16</h1>
        <p class="text-gray-300 text-lg">
          Angular framework — from fundamentals to advanced (Signals, Standalone
          Components, RxJS & more)
        </p>
      </div>

      <div class="space-y-8">
        {
          topics.map((topic) => (
            <div class="bg-white backdrop-blur-sm rounded-xl border border-purple-100 overflow-hidden shadow-sm">
              <div class="bg-gradient-to-r from-purple-50 to-blue-50 px-6 py-4 border-b border-gray-200">
                <h2 class="text-xl font-semibold">{topic.title}</h2>
              </div>
              <div class="divide-y divide-gray-100">
                {topic.questions.map((qa) => (
                  <div class="p-6">
                    <h3 class="text-purple-700 font-medium mb-3 flex items-start gap-2">
                      <span class="text-purple-600 mt-1">Q:</span>
                      {qa.q}
                    </h3>
                    <p class="text-gray-700 pl-6">
                      <span class="text-green-600 font-medium">A:</span>{" "}
                      <span set:html={qa.a} />
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
