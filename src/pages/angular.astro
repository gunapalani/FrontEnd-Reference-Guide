      {
        q: "What is NgRx and how does it work?",
        a: '<b><u>NgRx</u></b> is Angular\'s official state management library following <b>Redux</b> pattern.<br/><br/><b>Core concepts:</b><br/>• <b>Store</b> — single immutable state tree<br/>• <b>Actions</b> — events describing state changes (LoadUsers, AddUser)<br/>• <b>Reducers</b> — pure functions: (previousState, action) => newState<br/>• <b>Selectors</b> — query state efficiently (memoized)<br/>• <b>Effects</b> — handle side effects (HTTP calls, navigation)<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// 1. Define state shape\ninterface AppState {\n  users: User[];\n  loading: boolean;\n  error: string | null;\n}\n\n// 2. Create actions\nexport const loadUsers = createAction("[Users] Load Users");\nexport const loadUsersSuccess = createAction(\n  "[Users] Load Users Success",\n  props<{ users: User[] }>()\n);\n\n// 3. Create reducer\nconst initialState: AppState = { users: [], loading: false, error: null };\n\nconst usersReducer = createReducer(\n  initialState,\n  on(loadUsers, (state) => ({ ...state, loading: true })),\n  on(loadUsersSuccess, (state, { users }) => ({\n    ...state,\n    users,\n    loading: false\n  }))\n);\n\n// 4. Create effects (handle side effects)\n@Injectable()\nexport class UserEffects {\n  loadUsers$ = createEffect(() =>\n    this.actions$.pipe(\n      ofType(loadUsers),\n      switchMap(() =>\n        this.userService.getUsers().pipe(\n          map((users) => loadUsersSuccess({ users }))\n        )\n      )\n    )\n  );\n\n  constructor(\n    private actions$: Actions,\n    private userService: UserService\n  ) {}\n}\n\n// 5. Use in component\nexport class UserListComponent {\n  users$ = this.store.select(selectUsers);\n\n  constructor(private store: Store) {}\n\n  ngOnInit() {\n    this.store.dispatch(loadUsers());\n  }\n}</code></pre>',
      },
      {
        q: "What is the difference between Reducers and Selectors in NgRx?",
        a: '<b><u>Reducers</u></b> → <u>Update state</u> based on actions. Pure functions.<br/><b><u>Selectors</u></b> → <u>Read/query state</u> efficiently. Memoized to avoid unnecessary re-renders.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// Reducer — updates state\nconst reducer = createReducer(\n  initialState,\n  on(addUser, (state, { user }) => ({ ...state, users: [...state.users, user] }))\n);\n\n// Selector — queries state\nexport const selectUsers = (state: AppState) => state.users;\nexport const selectUserCount = createSelector(\n  selectUsers,\n  (users) => users.length  // memoized — only recalculates when users array changes\n);\n\n// Component\nthis.userCount$ = this.store.select(selectUserCount);</code></pre>',
      },
      {
        q: "What are Effects in NgRx?",
        a: '<b><u>Effects</u></b> handle <u>side effects</u> triggered by actions — API calls, navigation, logging, etc. Effects dispatch new actions based on results.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>@Injectable()\nexport class TodoEffects {\n  // Effect that returns a new action\n  loadTodos$ = createEffect(() =>\n    this.actions$.pipe(\n      ofType(loadTodos),\n      switchMap(() =>\n        this.api.getTodos().pipe(\n          map((todos) => loadTodosSuccess({ todos })),\n          catchError((err) => of(loadTodosError({ error: err.message })))\n        )\n      )\n    )\n  );\n\n  // Non-dispatching effect (side effect only, no new action)\n  saveTodo$ = createEffect(\n    () =>\n      this.actions$.pipe(\n        ofType(saveTodo),\n        tap(({ todo }) => console.log("Saved:", todo))\n      ),\n    { dispatch: false }  // No action dispatched\n  );\n\n  // Dispatch to navigate on success\n  loginSuccess$ = createEffect(\n    () =>\n      this.actions$.pipe(\n        ofType(loginSuccess),\n        tap(() => this.router.navigate(["/dashboard"]))\n      ),\n    { dispatch: false }\n  );\n\n  constructor(\n    private actions$: Actions,\n    private api: ApiService,\n    private router: Router\n  ) {}\n}</code></pre>',
      },
    ],
  },
  {
    title: "Testing in Angular",
    questions: [
      {
        q: "How do you write Unit Tests in Angular?",
        a: '<b><u>Unit tests</u></b> test individual components, services, and functions using <b>Jasmine</b> and <b>Karma</b>.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>import { ComponentFixture, TestBed } from "@angular/core/testing";\nimport { DebugElement } from "@angular/core";\nimport { By } from "@angular/platform-browser";\nimport { UserComponent } from "./user.component";\nimport { UserService } from "./user.service";\n\ndescribe("UserComponent", () => {\n  let component: UserComponent;\n  let fixture: ComponentFixture<UserComponent>;\n  let userService: jasmine.SpyObj<UserService>;\n\n  beforeEach(async () => {\n    const userServiceSpy = jasmine.createSpyObj("UserService", ["getUser"]);\n\n    await TestBed.configureTestingModule({\n      declarations: [UserComponent],\n      providers: [{ provide: UserService, useValue: userServiceSpy }]\n    }).compileComponents();\n\n    userService = TestBed.inject(UserService) as jasmine.SpyObj<UserService>;\n  });\n\n  beforeEach(() => {\n    fixture = TestBed.createComponent(UserComponent);\n    component = fixture.componentInstance;\n  });\n\n  it("should display user name", () => {\n    const mockUser = { id: 1, name: "John" };\n    userService.getUser.and.returnValue(of(mockUser));\n\n    fixture.detectChanges();  // Trigger ngOnInit\n\n    const element: DebugElement = fixture.debugElement.query(By.css("h1"));\n    expect(element.nativeElement.textContent).toContain("John");\n  });\n\n  it("should call getUser on init", () => {\n    fixture.detectChanges();\n    expect(userService.getUser).toHaveBeenCalled();\n  });\n});\n\nng test</code></pre>',
      },
      {
        q: "What are Jasmine matchers and how to use them?",
        a: '<b><u>Matchers</u></b> assert expected vs actual values in tests.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// Equality\nexpect(value).toBe(5);              // Strict equality (===)\nexpect(obj).toEqual({ id: 1 });     // Deep equality\n\n// Truthiness\nexpect(value).toBeTruthy();\nexpect(value).toBeFalsy();\n\n// Type checks\nexpect(value).toBeNull();\nexpect(value).toBeUndefined();\nexpect(value).toBeDefined();\n\n// Comparisons\nexpect(5).toBeGreaterThan(3);\nexpect(3).toBeLessThan(5);\n\n// Strings\nexpect("hello").toContain("ell");\nexpect("test@example.com").toMatch(/^[^@]+@[^@]+$/);\n\n// Arrays\nexpect([1, 2, 3]).toContain(2);\nexpect([]).toEqual(jasmine.arrayWithExactContents([]));\n\n// Spies\nexpect(spy).toHaveBeenCalled();\nexpect(spy).toHaveBeenCalledWith(arg);\nexpect(spy).toHaveBeenCalledTimes(3);\n\n// Errors\nexpect(() => { throw new Error() }).toThrowError();\nexpect(promise).rejectsWith(Error);</code></pre>',
      },
      {
        q: "What is TestBed in Angular testing?",
        a: '<b><u>TestBed</u></b> is the Angular testing utility that <u>configures a test module</u> similar to NgModule — provides dependencies, declares components, sets up mocks.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>beforeEach(async () => {\n  // Configure test module\n  await TestBed.configureTestingModule({\n    declarations: [UserComponent],\n    imports: [CommonModule, HttpClientTestingModule],\n    providers: [\n      UserService,\n      { provide: API_URL, useValue: "http://test.com" }  // Mock token\n    ]\n  }).compileComponents();  // Compile templates and CSS\n});\n\n// Get service from TestBed\nconst service = TestBed.inject(UserService);\nconst httpMock = TestBed.inject(HttpTestingController);\n\n// Create component (isolated from TestBed)\nfixture = TestBed.createComponent(UserComponent);\ncomponent = fixture.componentInstance;</code></pre>',
      },
      {
        q: "How do you test HTTP calls in Angular?",
        a: '<b><u>HttpClientTestingModule</u></b> provides <b>HttpTestingController</b> to mock HTTP requests in tests.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>let httpMock: HttpTestingController;\n\nbeforeEach(() => {\n  TestBed.configureTestingModule({\n    imports: [HttpClientTestingModule],\n    providers: [UserService]\n  });\n  httpMock = TestBed.inject(HttpTestingController);\n});\n\nit("should fetch users", () => {\n  const mockUsers = [{ id: 1, name: "Alice" }, { id: 2, name: "Bob" }];\n  const userService = TestBed.inject(UserService);\n\n  userService.getUsers().subscribe((users) => {\n    expect(users).toEqual(mockUsers);\n  });\n\n  // Expect and respond to HTTP request\n  const req = httpMock.expectOne("/api/users");\n  expect(req.request.method).toBe("GET");\n  req.flush(mockUsers);  // Send mock response\n});\n\nafterEach(() => {\n  httpMock.verify();  // Verify no outstanding HTTP requests\n});</code></pre>',
      },
    ],
  },
  {
    title: "Security & Best Practices",
    questions: [
      {
        q: "What are the security risks in Angular and how to prevent them?",
        a: '<b><u>XSS (Cross-Site Scripting)</u></b> → Inject malicious script. Angular sanitizes by default but use <b>bypassSecurityTrustHtml</b> carefully.<br/><b><u>CSRF</u></b> → Forge requests. Angular auto-includes CSRF tokens in HTTP headers.<br/><b><u>Injection attacks</u></b> → SQL, NoSQL. Use parameterized queries.\br/><b><u>Sensitive data exposure</u></b> → Use HTTPS, don\'t store secrets in code.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// ✅ Safe — Angular auto-escapes\n<p>{{ userInput }}</p>\n\n// ❌ Dangerous — can inject HTML/scripts\n<p [innerHTML]="userInput"></p>\n\n// ⚠️ If you must trust HTML, sanitize first\nimport { DomSanitizer } from "@angular/platform-browser";\n\nconstructor(private sanitizer: DomSanitizer) {}\n\ntrustedHtml = this.sanitizer.sanitize(SecurityContext.HTML, unsafeHtml);\n\n// ✅ Safe property binding\n<img [src]="imagePath" />\n\n// ❌ Avoid\n // Can inject javascript: URLs\n\n// CSRF protection — Angular includes X-XSRF-TOKEN automatically\n// Configure CSRF token names if needed:\nproviders: [\n  {\n    provide: HTTP_INTERCEPTORS,\n    useClass: AuthInterceptor\n  }\n]</code></pre>',
      },
      {
        q: "What are Angular Best Practices?",
        a: "<b>1. <u>Use OnPush Change Detection</u></b> — Better performance<br/><b>2. <u>Use async Pipe</u></b> — Auto-unsubscribe, simpler code<br/><b>3. <u>Lazy Load Modules</u></b> — Reduce initial bundle<br/><b>4. <u>Unsubscribe in ngOnDestroy</u></b> — Prevent memory leaks<br/><b>5. <u>Use Standalone Components</u></b> — No NgModule boilerplate<br/><b>6. <u>Immutable State</u></b> — Use immutable updates (spread operator, immer.js)<br/><b>7. <u>Environment-specific Configs</u></b> — Different API URLs per environment<br/><b>8. <u>Consistent Naming</u></b> — Components: PascalCase, files: kebab-case, observables: $ suffix<br/><b>9. <u>Avoid Direct DOM Access</u></b> — Use Renderer2, ViewChild<br/><b>10. <u>Keep Components Simple</u></b> — Delegation to services, single responsibility",
      },
      {
        q: "What is sanitization in Angular?",
        a: '<b><u>Sanitization</u></b> removes dangerous code from values before rendering them to prevent XSS attacks. Angular uses <b>DomSanitizer</b>.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>import { DomSanitizer, SafeHtml } from "@angular/platform-browser";\n\nexport class SafeComponent {\n  constructor(private sanitizer: DomSanitizer) {}\n\n  // Sanitize HTML\n  safeHtml: SafeHtml = this.sanitizer.sanitize(\n    SecurityContext.HTML,\n    "<p>Safe content</p>"\n  ) || "";\n\n  // Bypass sanitization (use only if content is trusted)\n  trustedHtml = this.sanitizer.bypassSecurityTrustHtml(\n    "<p>Trusted content</p>"\n  );\n\n  // Template\n  // <div [innerHTML]="safeHtml"></div>\n}\n\n// Security contexts:\n// • HTML — body, div\n// • STYLE — style attribute\n// • SCRIPT — <script> tags\n// • URL — href, src\n// • RESOURCE_URL — <script src>, <link href></code></pre>',
      },
    ],
  },
  {
    title: "Error Handling & Debugging",
    questions: [
      {
        q: "How do you handle errors in RxJS Observables?",
        a: '<b><u>catchError</u></b> catches Observable errors. <b><u>throwError</u></b> converts to error. <b><u>retry</u></b> automatically retries on error.<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// Catch and handle error\nthis.http.get("/api/users").pipe(\n  catchError((error: HttpErrorResponse) => {\n    if (error.status === 404) {\n      return of([]);  // Return empty array\n    } else if (error.status === 401) {\n      this.router.navigate(["/login"]);\n      return throwError(() => new Error("Unauthorized"));\n    }\n    return throwError(() => error);\n  })\n).subscribe();\n\n// Retry logic\nthis.http.get("/api/users").pipe(\n  retry(3),  // Retry up to 3 times on error\n  catchError((err) => {\n    console.error("Failed after 3 retries:", err);\n    return of([]);\n  })\n).subscribe();\n\n// Retry with delay/backoff (exponential)\nretryWhen((errors) =>\n  errors.pipe(\n    mergeMap((error, index) =>\n      index < 3 ? timer(Math.pow(2, index) * 1000) : throwError(() => error)\n    )\n  )\n);\n\n// finalize — cleanup regardless of success/error\nthis.http.get("/api").pipe(\n  finalize(() => console.log("Request completed (success or error)"))\n).subscribe();</code></pre>',
      },
      {
        q: "How do you debug Angular applications?",
        a: '<b>1. <u>Browser DevTools</u></b> → Set breakpoints, step through code, inspect variables<br/><b>2. <u>Angular DevTools (Chrome Extension)</u></b> → Inspect components, debug change detection, view dependency tree<br/><b>3. <u>console.log / debugger</u></b> → Log values, pause execution<br/><b>4. <u>Source Maps</u></b> → Debug TypeScript instead of JavaScript (enabled in dev mode)<br/><b>5. <u>Network tab</u></b> → Monitor HTTP requests, check payloads, latency<br/><b>6. <u>Profiler</u></b> → Record and analyze CPU usage, identify performance bottlenecks<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// Debugging tips\n// Use debugger keyword to pause execution\nngOnInit() {\n  debugger;  // Execution pauses here\n  this.loadData();\n}\n\n// Log Objects nicely\nconsole.table(this.users);\nconsole.group("User Data");\nconsole.log("Name:", this.user.name);\nconsole.log("Age:", this.user.age);\nconsole.groupEnd();\n\n// Monitor Observable emissions\nthis.data$.pipe(\n  tap((value) => console.log("Data received:", value))\n).subscribe();</code></pre>',
      },
      {
        q: "What is Error Boundary in Angular?",
        a: "<b><u>Angular doesn't have native Error Boundary</u></b> like React, but you can create one using <b>ErrorHandler</b>.<br/><br/>Create a global error handler to catch unhandled errors and display them gracefully instead of crashing the app.",
      },
    ],
  },
  {
    title: "Advanced Topics",
    questions: [
      {
        q: "What are Decorators in Angular?",
        a: '<b><u>Decorators</u></b> are functions that <u>modify classes, methods, properties, or parameters</u>. They use <b>@</b> prefix and are called at class definition time.<br/><br/><b>Common decorators:</b><br/>• <b>@Component</b> — Declare component<br/>• <b>@Directive</b> — Declare directive<br/>• <b>@Injectable</b> — Mark as dependency injection service<br/>• <b>@Input/@Output</b> — Component communication<br/>• <b>@ViewChild/@ContentChild</b> — Access DOM elements<br/>• <b>@HostBinding/@HostListener</b> — Host element manipulation<br/>• <b>@NgModule</b> — Declare module<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>// Property decorator\nbool = true;\n\n// Class decorator\n@Component({ /* ... */ })\nexport class MyComponent {}\n\n// Method decorator (rare)\nclass MyClass {\n  @LogCall()  // Custom decorator\n  myMethod() {}\n}\n\n// Parameter decorator\nfunction Validate(target: any, key: string, index: number) {}\n\nclass MyClass {\n  myMethod(@Validate() value: string) {}\n}</code></pre>',
      },
      {
        q: "What is the difference between View Encapsulation modes?",
        a: '<b><u>View Encapsulation</u></b> controls how component styles are scoped. Angular supports 3 modes:<br/><br/><b>1. ViewEncapsulation.Emulated (default)</b> → Shadow DOM-like behavior (styles scoped via generated attributes)<br/><b>2. ViewEncapsulation.ShadowDom</b> → Uses native Shadow DOM (real encapsulation, not all browsers)<br/><b>3. ViewEncapsulation.None</b> → No encapsulation (styles global)<br/><br/><pre class="bg-gray-800 text-gray-100 p-3 rounded-lg mt-2 overflow-x-auto text-sm"><code>@Component({\n  selector: "app-card",\n  template: `<div class="card">Content</div>`,\n  styles: [`.card { color: blue; }`],\n  encapsulation: ViewEncapsulation.Emulated  // Default\n})\nexport class CardComponent {}\n\n// Generated HTML (Emulated):\n// <div class="card _ngcontent-ng-c1234">Content</div>\n// CSS becomes: .card[_ngcontent-ng-c1234] { color: blue; }\n\n// With ShadowDom:\n// Real Shadow DOM tree, styles completely isolated\n\n// With None:\n// Styles are global, can leak to other components</code></pre>',
      },
      {
        q: "What is Zone.js in Angular?",
        a: '<b><u>Zone.js</u></b> is a library Angular uses to <u>patch async operations</u> (setTimeout, Promise, events) and <u>trigger change detection</u> automatically.<br/><br/>When async operations complete, Zone.js notifies Angular to run change detection — ensuring the UI updates.<br/><br/><b>Angular 18+ allows "zoneless" apps</b> using Signals for more efficient change detection (experimental).',
      },
      {
        q: "What is Hydration in Angular?",
        a: "<b><u>Hydration</u></b> (Angular 16) is the process of <u>reusing server-rendered HTML</u> on the client instead of destroying and re-rendering.<br/><br/>Benefits:<br/>• <u>Faster initial load</u> — No white flash<br/>• <u>Better Core Web Vitals</u> — FCP, LCP improve<br/>• <u>SEO friendly</u> — HTML available immediately<br/>• <u>Prevents double rendering</u> — Server HTML + client hydration",
      },
      {
        q: "What is Module Federation in Angular?",
        a: "<b><u>Module Federation</u></b> (Webpack 5) allows <u>loading separate Angular apps at runtime</u> from different deployments — enabling independent development and deployment of app pieces.<br/><br/>Use case: Micro-frontends — multiple teams work on different features independently.",
      },
    ],
  },
];

const totalQuestions = topics.reduce(
  (sum, topic) => sum + topic.questions.length,
  0,
);
---

<Layout>
  <div
    class="min-h-screen"
    style="background: linear-gradient(to bottom right, #1f1472, #37147d, #53199e);"
  >
    <!-- Main Content -->
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="mb-12">
        <h1 class="text-5xl font-bold text-white mb-4">Angular 16</h1>
        <p class="text-gray-300 text-lg">
          Angular framework — from fundamentals to advanced (Signals, Standalone
          Components, RxJS & more)
        </p>
        <p class="text-purple-200 text-lg font-semibold mt-4">
          📚 Total Questions: <span class="text-yellow-300"
            >{totalQuestions}</span
          >
        </p>
      </div>

      <div class="space-y-8">
        {
          topics.map((topic) => (
            <div class="bg-white backdrop-blur-sm rounded-xl border border-purple-100 overflow-hidden shadow-sm">
              <div class="bg-gradient-to-r from-purple-50 to-blue-50 px-6 py-4 border-b border-gray-200">
                <h2 class="text-xl font-semibold">{topic.title}</h2>
              </div>
              <div class="divide-y divide-gray-100">
                {topic.questions.map((qa) => (
                  <div class="p-6">
                    <h3 class="text-purple-700 font-medium mb-3 flex items-start gap-2">
                      <span class="text-purple-600 mt-1">Q:</span>
                      {qa.q}
                    </h3>
                    <p class="text-gray-700 pl-6">
                      <span class="text-green-600 font-medium">A:</span>{" "}
                      <span set:html={qa.a} />
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
